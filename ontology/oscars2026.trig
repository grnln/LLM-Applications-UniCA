    :country        "Norway" ;
    :language       "Norwegian" ;
    :genre          "drama" ;
    :totalWins      "1"^^xsd:integer ;
    :milestone      "first Norwegian film to win Best International Feature" .

:MartySupreme
    rdfs:label      "Marty Supreme" ;
    :directedBy     :JoshSafdie ;
    :starring       :TimotheeChalamet ;
    :subject        "table tennis" ;
    :genre          "drama" ;
    :distributedBy  "A24" ;
    :totalNominations "9"^^xsd:integer ;
    :totalWins      "0"^^xsd:integer .

:Bugonia
    rdfs:label      "Bugonia" ;
    :directedBy     :YorgosLanthimos ;
    :starring       :EmmaStone , :JessePlemons ;
    :basedOn        "the South Korean film Save the Green Planet!" ;
    :genre          "dark comedy thriller" .

:Weapons
    rdfs:label      "Weapons" ;
    :directedBy     :ZachCregger ;
    :starring       :AmyMadigan , :JuliaGarner , :JoshBrolin ;
    :genre          "horror" ;
    :totalWins      "1"^^xsd:integer .

:KPopDemonHunters
    rdfs:label      "KPop Demon Hunters" ;
    :directedBy     :MaggieKang , :ChrisAppelhans ;
    :genre          "animated musical" ;
    :distributedBy  "Netflix" ;
    :totalWins      "2"^^xsd:integer .

:TheSecretAgent
    rdfs:label      "The Secret Agent" ;
    :directedBy     :KleberMendoncaFilho ;
    :starring       :WagnerMoura ;
    :country        "Brazil" ;
    :setting        "Recife, 1977" ;
    :language       "Portuguese" ;
    :genre          "thriller" .

:F1
    rdfs:label      "F1" ;
    :directedBy     :JosephKosinski ;
    :starring       :BradPitt ;
    :genre          "sports drama" .

:TrainDreams
    rdfs:label      "Train Dreams" ;
