@prefix :    <http://oscars2026.org#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# 98th Academy Awards (March 2026) — hand-built knowledge graph.
# Designed to COMPLEMENT the plain-text corpus: the corpus describes the films
# (plot, cast, production) and states NO outcomes. Every award result, count,
# and milestone lives ONLY here, so the two sources genuinely complement each
# other. Convention: a winner has :wonAward; a nominee who lost has :nominatedFor.

:oscars2026 {

# ---------------------------------------------------------------------------
# Ceremony
# ---------------------------------------------------------------------------
:Oscars98
    rdfs:label            "98th Academy Awards" ;
    :ceremonyDate         "2026-03-15"^^xsd:date ;
    :venue                "Dolby Theatre, Hollywood, Los Angeles" ;
    :hostedBy             :ConanOBrien ;
    :honorsFilmsFrom      "2025"^^xsd:gYear ;
    :introducedNewCategory :BestCasting .

:ConanOBrien
    rdfs:label   "Conan O'Brien" ;
    :hostingNote "hosted the Oscars for the second consecutive year" .

:BestCasting
    :milestone "first new competitive Oscar category since Best Animated Feature in 2001" .

# ---------------------------------------------------------------------------
# Films (descriptive metadata + relations)
# ---------------------------------------------------------------------------
:OneBattleAfterAnother
    rdfs:label      "One Battle After Another" ;
    :directedBy     :PaulThomasAnderson ;
    :writtenBy      :PaulThomasAnderson ;
    :starring       :LeonardoDiCaprio , :SeanPenn , :BenicioDelToro , :TeyanaTaylor , :ChaseInfiniti ;
    :basedOn        "the novel Vineland by Thomas Pynchon" ;
    :genre          "action drama" ;
    :distributedBy  "Warner Bros." ;
    :totalWins      "6"^^xsd:integer .

:Sinners
    rdfs:label      "Sinners" ;
    :directedBy     :RyanCoogler ;
    :writtenBy      :RyanCoogler ;
    :starring       :MichaelBJordan , :WunmiMosaku , :DelroyLindo , :HaileeSteinfeld ;
    :setting        "1932 Mississippi Delta" ;
    :genre          "supernatural horror" ;
    :distributedBy  "Warner Bros." ;
    :totalWins      "4"^^xsd:integer ;
    :totalNominations "16"^^xsd:integer ;
    :recordNote     "set an all-time record with 16 nominations" .

:Hamnet
    rdfs:label      "Hamnet" ;
    :directedBy     :ChloeZhao ;
    :starring       :JessieBuckley , :PaulMescal ;
    :basedOn        "the novel Hamnet by Maggie O'Farrell" ;
    :genre          "historical drama" ;
    :distributedBy  "Focus Features" ;
    :totalWins      "1"^^xsd:integer .

:Frankenstein
    rdfs:label      "Frankenstein" ;
    :directedBy     :GuillermoDelToro ;
    :starring       :OscarIsaac , :JacobElordi , :MiaGoth ;
    :basedOn        "the novel by Mary Shelley" ;
    :genre          "gothic horror" ;
    :distributedBy  "Netflix" ;
    :totalWins      "3"^^xsd:integer .

:SentimentalValue
    rdfs:label      "Sentimental Value" ;
    :directedBy     :JoachimTrier ;
