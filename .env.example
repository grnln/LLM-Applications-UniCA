# GraphDB -----------
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPOSITORY=BIP-DB
GRAPHDB_ONTOLOGY_FILE=ontology/oscars.trig
GRAPHDB_NAMESPACE=http://oscars2026.org#

# Local LLM (Ollama)
# Install Ollama, then: `ollama pull qwen2.5-coder:7b`
OLLAMA_MODEL=qwen2.5-coder:7b

# Text RAG (Weaviate + SentenceTransformer)
# Weaviate runs at http://localhost:8080 via docker-compose.
OSCAR_TEXT_FILE=ontology/oscar.txt
WEAVIATE_COLLECTION=OscarFilms
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TEXT_RAG_TOP_K=3

# API
PORT=5000
